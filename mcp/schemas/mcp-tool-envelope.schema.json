{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heydoc.local/schemas/mcp-tool-envelope.schema.json",
  "title": "MCPToolEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["tool", "input", "meta"],
  "properties": {
    "tool": {
      "type": "string",
      "description": "Fully-qualified tool name (e.g., docs.search, kg.query, terminology.lookup)."
    },
    "input": { "type": "object" },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_id", "mode", "issued_at_utc"],
      "properties": {
        "request_id": { "type": "string" },
        "mode": { "type": "string", "enum": ["live", "dry_run", "mock"] },
        "issued_at_utc": { "type": "string", "format": "date-time" }
      }
    }
  }
}

