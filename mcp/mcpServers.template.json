{
  "mcpServers": {
    "docs": {
      "command": "node",
      "args": ["mcp/servers/docs/dist/index.js"],
      "env": {
        "HEYDOC_ENV": "local",
        "HEYDOC_DATA_DIR": "${workspaceFolder}/.heydoc-data",
        "HEYDOC_DOCS_DIR": "${workspaceFolder}/docs",
        "HEYDOC_DOCS_INDEX_DIR": "${workspaceFolder}/docs/index",
        "HEYDOC_MODE_DEFAULT": "mock"
      }
    },
    "knowledge": {
      "command": "node",
      "args": ["mcp/servers/knowledge/dist/index.js"],
      "env": {
        "HEYDOC_ENV": "local",
        "HEYDOC_DATA_DIR": "${workspaceFolder}/.heydoc-data",
        "HEYDOC_KG_DB_URL": "postgres://heydoc:heydoc@localhost:5432/heydoc",
        "HEYDOC_MODE_DEFAULT": "mock"
      }
    },
    "identity-au": {
      "command": "node",
      "args": ["mcp/servers/identity-au/dist/index.js"],
      "env": {
        "HEYDOC_ENV": "local",
        "HEYDOC_MODE_DEFAULT": "mock",
        "AU_IHI_PROVIDER": "stub",
        "AU_IHI_ENDPOINT": "https://example.invalid/ihi",
        "AU_IHI_MTLS_CERT_PATH": "",
        "AU_IHI_MTLS_KEY_PATH": ""
      }
    },
    "terminology": {
      "command": "node",
      "args": ["mcp/servers/terminology/dist/index.js"],
      "env": {
        "HEYDOC_ENV": "local",
        "HEYDOC_MODE_DEFAULT": "mock",
        "SNOMED_ENDPOINT": "https://example.invalid/snomed",
        "ICD11_ENDPOINT": "https://example.invalid/icd11",
        "TERMINOLOGY_UPSTREAM_NAME": "stub"
      }
    },
    "fhir-broker": {
      "command": "node",
      "args": ["mcp/servers/fhir-broker/dist/index.js"],
      "env": {
        "HEYDOC_ENV": "local",
        "HEYDOC_MODE_DEFAULT": "mock",
        "FHIR_BASE_URL": "https://example.invalid/fhir",
        "FHIR_AUTH_MODE": "stub"
      }
    },
    "pharmacology": {
      "command": "node",
      "args": ["mcp/servers/pharmacology/dist/index.js"],
      "env": {
        "HEYDOC_ENV": "local",
        "HEYDOC_MODE_DEFAULT": "mock",
        "PHARM_VENDOR": "stub",
        "PHARM_ENDPOINT": "https://example.invalid/pharm"
      }
    },
    "messaging-geo": {
      "command": "node",
      "args": ["mcp/servers/messaging-geo/dist/index.js"],
      "env": {
        "HEYDOC_ENV": "local",
        "HEYDOC_MODE_DEFAULT": "mock",
        "MSG_PROVIDER": "stub",
        "GEO_PROVIDER": "stub",
        "PHARMACY_DIRECTORY_PROVIDER": "stub"
      }
    }
  }
}

